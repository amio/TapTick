<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>TapTick</string>
    <key>CFBundleDisplayName</key>
    <string>TapTick</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright 2026 TapTick. All rights reserved.</string>

    <!-- Required by App Store Connect / notarization submission:
         false = the app does NOT use non-exempt encryption (no export compliance review needed) -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- Sparkle auto-update: appcast feed URL hosted on GitHub Pages -->
    <key>SUFeedURL</key>
    <string>https://amio.github.io/TapTick/appcast.xml</string>

    <!-- Sparkle auto-update: EdDSA (ed25519) public key for verifying update signatures.
         Generate a keypair with: ./bin/generate_keys (from Sparkle distribution).
         Replace this placeholder with your actual public key. -->
    <key>SUPublicEDKey</key>
    <string>$(SPARKLE_ED_PUBLIC_KEY)</string>
</dict>
</plist>