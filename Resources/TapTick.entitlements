<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- iCloud Drive container access for cross-device shortcut sync.
         DISABLED: requires a Developer ID provisioning profile with iCloud
         capability registered in the Apple Developer Portal. Re-enable once
         the profile is created and added to the project.
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.taptick.app</string>
    </array>
    <key>com.apple.developer.ubiquity-container-identifiers</key>
    <array>
        <string>iCloud.com.taptick.app</string>
    </array>
    -->

    <!-- Hardened Runtime: allow child processes to run unsigned executables
         (needed by ShortcutExecutor when invoking user shell scripts) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>

    <!-- Hardened Runtime: allow loading unsigned libraries / frameworks
         (needed by CGEventTap in HotkeyService) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>
</dict>
</plist>